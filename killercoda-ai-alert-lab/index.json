{
  "title": "AIが提案したアラート抑制ルールの修正",
  "description": "AIが生成したアラート抑制ルールにより、本来検知すべき本番障害が見逃される状態を修正するDockerベースの短時間演習です。",
  "difficulty": "Beginner",
  "time": "10 minutes",
  "details": {
    "intro": {
      "text": "intro.md",
      "foreground": "setup.sh"
    },
    "steps": [
      {
        "title": "Investigate the Incident",
        "text": "step1.md"
      },
      {
        "title": "Verify the Fix",
        "text": "step2.md",
        "verify": "step2/verify.sh"
      }
    ],
    "finish": {
      "text": "finish.md"
    },
    "assets": {
      "host01": [
        {
          "file": "lab-files/docker-compose.yml",
          "target": "/root/lab/lab-files",
          "chmod": "+w"
        },
        {
          "file": "lab-files/ai_note.md",
          "target": "/root/lab/lab-files",
          "chmod": "+w"
        },
        {
          "file": "lab-files/check_alert.sh",
          "target": "/root/lab/lab-files",
          "chmod": "+x"
        },
        {
          "file": "lab-files/monitor/alert_rules.conf",
          "target": "/root/lab/lab-files/monitor",
          "chmod": "+w"
        },
        {
          "file": "lab-files/sample_logs/real_incident.log",
          "target": "/root/lab/lab-files/sample_logs",
          "chmod": "+w"
        },
        {
          "file": "lab-files/sample_logs/noise.log",
          "target": "/root/lab/lab-files/sample_logs",
          "chmod": "+w"
        }
      ]
    }
  },
  "backend": {
    "imageid": "ubuntu"
  }
}
